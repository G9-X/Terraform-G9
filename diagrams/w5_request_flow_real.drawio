        <!-- Components -->
        <mxCell id="ecs" value="ECS Tasks / EC2&#xa;[Private App Subnet]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2F8;strokeColor=#147EBA;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="200" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="nfw" value="Network Firewall Endpoint&#xa;[Firewall Subnet]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAD7DD;strokeColor=#DD344C;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="200" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="nat" value="NAT Gateway&#xa;[Public Subnet]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8C4FFF;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="950" y="200" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="internet" value="Malicious Domain / Internet" style="ellipse;cloud;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#232F3E;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1350" y="180" width="200" height="140" as="geometry" />
        </mxCell>

        <!-- Arrows with detailed labels -->
        <mxCell id="arr1" style="strokeWidth=2;strokeColor=#232F3E;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="ecs" target="nfw" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl1" value="1. App Route Table&#xa;Dest: 0.0.0.0/0&#xa;Target: VPCE Endpoint" style="edgeLabel;html=1;fontSize=11;fontColor=#232F3E;align=center;" vertex="1" connectable="0" parent="arr1">
          <mxGeometry x="-0.1" y="25" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="arr2" style="strokeWidth=3;strokeColor=#DD344C;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="nfw" target="nat" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl2" value="2. Inspect Traffic&#xa;Check Suricata Rules&#xa;ALLOW / DROP" style="edgeLabel;html=1;fontSize=12;fontColor=#DD344C;fontStyle=1;align=center;" vertex="1" connectable="0" parent="arr2">
          <mxGeometry x="-0.1" y="30" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="arr3" style="strokeWidth=2;strokeColor=#232F3E;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" source="nat" target="internet" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl3" value="3. Forward Verified&#xa;Traffic to Internet" style="edgeLabel;html=1;fontSize=11;fontColor=#232F3E;align=center;" vertex="1" connectable="0" parent="arr3">
