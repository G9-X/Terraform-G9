        <!-- Legend box for MH2 explanation -->
        <mxCell id="info" value="&lt;b&gt;MH2 Hardening Logic:&lt;/b&gt;&#xa;Traffic from App instances is forced through the Firewall Endpoint&#xa;before reaching the NAT Gateway via Route Table manipulation.&#xa;This allows deep packet inspection and domain filtering." style="text;html=1;strokeColor=#DD344C;fillColor=#FFF;padding=10;fontSize=12;whiteSpace=wrap;" vertex="1" parent="1">
