project_name = "xbrain"
environment  = "us-dev-static"
aws_region   = "us-east-1"

# Leave empty if you do not use custom domain.
domain_name    = ""
hosted_zone_id = ""

index_document = "index.html"
error_document = "index.html"

# CloudFront (pay-as-you-go)
enable_cloudfront  = true

# Optional: ACM cert in us-east-1, required only when using custom domain on CloudFront.
acm_certificate_arn = ""

# Dedicated GitHub Actions OIDC role for frontend deploy
enable_github_actions_oidc_frontend = true
create_github_oidc_provider         = false
existing_github_oidc_provider_arn   = ""
github_actions_role_name_frontend   = "xbrain-frontend-actions-us-dev"
github_repo_owner                   = "G9-X"
github_repo_name                    = "Merxly-XB9"
github_branch                       = "main"
